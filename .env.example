# LLM providers
GROQ_API_KEY_1=your_groq_key_1
GROQ_API_KEY_2=your_groq_key_2
CEREBRAS_API_KEY=your_cerebras_key

# Trello (optionnel — si absent, les echecs sont logges en console)
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=

# Mission Control
MC_BASE_URL=http://localhost:8000
MC_AGENT_NAME=rf_agent

# Cache (mettre "1" pour eviter de re-crawler les apps connues)
RF_USE_CACHE=1
